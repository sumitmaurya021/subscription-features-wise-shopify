{% liquid
  assign review_selection = block.settings.review_selection | default: 'current_product'

  assign resolved_review_type = 'store'
  assign resolved_target_id = ''
  assign resolved_target_handle = ''
  assign resolved_target_title = shop.name
  assign resolved_context_image = ''
  assign add_to_cart_variant_id = ''

  if review_selection == 'store_reviews'
    assign resolved_review_type = 'store'
    assign resolved_target_title = shop.name

  elsif review_selection == 'custom_product' and block.settings.custom_product != blank
    assign resolved_review_type = 'product'
    assign resolved_target_id = block.settings.custom_product.id
    assign resolved_target_handle = block.settings.custom_product.handle
    assign resolved_target_title = block.settings.custom_product.title

    if block.settings.custom_product.featured_image
      assign resolved_context_image = block.settings.custom_product.featured_image | image_url: width: 500
    endif

    if block.settings.custom_product.selected_or_first_available_variant
      assign add_to_cart_variant_id = block.settings.custom_product.selected_or_first_available_variant.id
    endif

  elsif review_selection == 'current_collection' and collection
    assign resolved_review_type = 'collection'
    assign resolved_target_id = collection.id
    assign resolved_target_handle = collection.handle
    assign resolved_target_title = collection.title

    if collection.image
      assign resolved_context_image = collection.image | image_url: width: 500
    endif

  elsif template.name == 'product' and product
    assign resolved_review_type = 'product'
    assign resolved_target_id = product.id
    assign resolved_target_handle = product.handle
    assign resolved_target_title = product.title

    if product.featured_image
      assign resolved_context_image = product.featured_image | image_url: width: 500
    endif

    if product.selected_or_first_available_variant
      assign add_to_cart_variant_id = product.selected_or_first_available_variant.id
    endif

  elsif template.name == 'collection' and collection
    assign resolved_review_type = 'collection'
    assign resolved_target_id = collection.id
    assign resolved_target_handle = collection.handle
    assign resolved_target_title = collection.title

    if collection.image
      assign resolved_context_image = collection.image | image_url: width: 500
    endif
  endif

  assign resolved_min_rating = ''
  if block.settings.min_rating != blank and block.settings.min_rating != 'all'
    assign resolved_min_rating = block.settings.min_rating
  endif

  assign can_show_add_to_cart = false
  if block.settings.show_add_to_cart and resolved_review_type == 'product' and add_to_cart_variant_id != blank
    assign can_show_add_to_cart = true
  endif
%}

<style>
  #rsn-root-{{ block.id }} {
    --rsn-card-bg: {{ block.settings.card_bg }};
    --rsn-text-color: {{ block.settings.text_color }};
    --rsn-star-color: {{ block.settings.star_color }};
    --rsn-arrow-bg: {{ block.settings.arrow_bg }};
    --rsn-arrow-color: {{ block.settings.arrow_color }};
    --rsn-border-color: {{ block.settings.border_color }};
    --rsn-card-radius: {{ block.settings.card_radius }}px;
    --rsn-card-padding: {{ block.settings.card_padding }}px;
    --rsn-card-max-width: {{ block.settings.card_max_width }}px;
    --rsn-card-min-height: {{ block.settings.card_min_height }}px;
    --rsn-name-size: {{ block.settings.reviewer_name_size }}px;
    --rsn-text-size: {{ block.settings.review_text_size }}px;
    --rsn-section-pad-top: {{ block.settings.section_padding_top }}px;
    --rsn-section-pad-bottom: {{ block.settings.section_padding_bottom }}px;
    --rsn-button-bg: {{ block.settings.button_bg }};
    --rsn-button-text: {{ block.settings.button_text_color }};
    --rsn-button-radius: {{ block.settings.button_radius }}px;
  }

  #rsn-root-{{ block.id }}.rsn-root {
    padding-top: var(--rsn-section-pad-top);
    padding-bottom: var(--rsn-section-pad-bottom);
  }

  #rsn-root-{{ block.id }} .rsn-preview-wrap {
    position: relative;
    max-width: var(--rsn-card-max-width);
    margin: 0 auto;
    min-height: var(--rsn-card-min-height);
  }

  #rsn-root-{{ block.id }} .rsn-preview-card {
    position: relative;
    background: var(--rsn-card-bg);
    color: var(--rsn-text-color);
    border: 1px solid var(--rsn-border-color);
    border-radius: var(--rsn-card-radius);
    padding: var(--rsn-card-padding);
    min-height: var(--rsn-card-min-height);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #rsn-root-{{ block.id }} .rsn-preview-top {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  #rsn-root-{{ block.id }} .rsn-preview-stars {
    color: var(--rsn-star-color);
    font-size: 34px;
    line-height: 1;
    letter-spacing: 2px;
    white-space: nowrap;
  }

  #rsn-root-{{ block.id }} .rsn-preview-name {
    margin: 0;
    font-size: var(--rsn-name-size);
    line-height: 1.15;
    font-weight: 700;
    color: var(--rsn-text-color);
  }

  #rsn-root-{{ block.id }} .rsn-preview-text {
    margin: 0;
    font-size: var(--rsn-text-size);
    line-height: 1.55;
    color: var(--rsn-text-color);
  }

  #rsn-root-{{ block.id }} .rsn-preview-actions {
    margin-top: 18px;
    display: flex;
    justify-content: flex-start;
  }

  #rsn-root-{{ block.id }} .rsn-preview-add-btn {
    appearance: none;
    border: none;
    cursor: pointer;
    background: var(--rsn-button-bg);
    color: var(--rsn-button-text);
    min-height: 46px;
    padding: 12px 20px;
    border-radius: var(--rsn-button-radius);
    font-size: 15px;
    line-height: 1;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #rsn-root-{{ block.id }} .rsn-preview-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border: 1px solid var(--rsn-border-color);
    border-radius: 999px;
    background: var(--rsn-arrow-bg);
    color: var(--rsn-arrow-color);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
    z-index: 2;
    pointer-events: none;
    font-size: 30px;
    line-height: 1;
  }

  #rsn-root-{{ block.id }} .rsn-preview-arrow--prev {
    left: -24px;
  }

  #rsn-root-{{ block.id }} .rsn-preview-arrow--next {
    right: -24px;
  }

  @media screen and (max-width: 749px) {
    #rsn-root-{{ block.id }} .rsn-preview-wrap {
      max-width: 100%;
    }

    #rsn-root-{{ block.id }} .rsn-preview-card {
      min-height: auto;
      padding: 20px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-stars {
      font-size: 26px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-name {
      font-size: calc(var(--rsn-name-size) - 4px);
    }

    #rsn-root-{{ block.id }} .rsn-preview-text {
      font-size: calc(var(--rsn-text-size) - 2px);
    }

    #rsn-root-{{ block.id }} .rsn-preview-arrow {
      width: 42px;
      height: 42px;
      font-size: 28px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-arrow--prev {
      left: -10px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-arrow--next {
      right: -10px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-actions {
      margin-top: 16px;
    }

    #rsn-root-{{ block.id }} .rsn-preview-add-btn {
      width: 100%;
    }
  }
</style>

<div
  id="rsn-root-{{ block.id }}"
  class="rsn-root"
  data-block-id="{{ block.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-endpoint="/apps/reviews"
  data-review-selection="{{ review_selection }}"
  data-review-type="{{ resolved_review_type }}"
  data-target-id="{{ resolved_target_id }}"
  data-target-handle="{{ resolved_target_handle }}"
  data-target-title="{{ resolved_target_title | escape }}"
  data-context-image="{{ resolved_context_image }}"
  data-min-rating="{{ resolved_min_rating }}"
  data-max-reviews="{{ block.settings.max_reviews }}"
  data-show-arrows="{{ block.settings.show_arrows }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-pause-on-hover="{{ block.settings.pause_on_hover }}"
  data-show-reviewer-name="{{ block.settings.show_reviewer_name }}"
  data-show-verified-badge="{{ block.settings.show_verified_badge }}"
  data-excerpt-length="{{ block.settings.excerpt_length }}"
  data-card-max-width="{{ block.settings.card_max_width }}"
  data-card-min-height="{{ block.settings.card_min_height }}"
  data-card-padding="{{ block.settings.card_padding }}"
  data-card-radius="{{ block.settings.card_radius }}"
  data-card-bg="{{ block.settings.card_bg }}"
  data-text-color="{{ block.settings.text_color }}"
  data-star-color="{{ block.settings.star_color }}"
  data-arrow-bg="{{ block.settings.arrow_bg }}"
  data-arrow-color="{{ block.settings.arrow_color }}"
  data-border-color="{{ block.settings.border_color }}"
  data-shadow-strength="{{ block.settings.shadow_strength }}"
  data-reviewer-name-size="{{ block.settings.reviewer_name_size }}"
  data-review-text-size="{{ block.settings.review_text_size }}"
  data-empty-text="{{ block.settings.empty_text | escape }}"
  data-show-add-to-cart="{{ can_show_add_to_cart }}"
  data-add-to-cart-label="{{ block.settings.add_to_cart_label | escape }}"
  data-add-to-cart-variant-id="{{ add_to_cart_variant_id }}"
  data-redirect-to-cart="{{ block.settings.redirect_to_cart }}"
  data-main-script="{{ 'review-snippets-main.js' | asset_url }}"
  {{ block.shopify_attributes }}
>
  <div class="rsn-preview-wrap">
    {% if block.settings.show_arrows %}
      <span class="rsn-preview-arrow rsn-preview-arrow--prev" aria-hidden="true">‹</span>
    {% endif %}

    <div class="rsn-preview-card">
      <div class="rsn-preview-top">
        <div class="rsn-preview-stars">★★★★★</div>
        <h3 class="rsn-preview-name">Darlene Robertson</h3>
      </div>

      <p class="rsn-preview-text">
        The USB smoothie blender is incredibly convenient for on-the-go use, blending fruits and veggies effortlessly in seconds….
      </p>

      {% if can_show_add_to_cart %}
        <div class="rsn-preview-actions">
          <button type="button" class="rsn-preview-add-btn">
            {{ block.settings.add_to_cart_label }}
          </button>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_arrows %}
      <span class="rsn-preview-arrow rsn-preview-arrow--next" aria-hidden="true">›</span>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Review Snippets",
  "target": "section",
  "templates": ["product", "collection", "index"],
  "javascript": "review-snippets.js",
  "stylesheet": "review-snippets.css",
  "settings": [
    {
      "type": "header",
      "content": "Review source"
    },
    {
      "type": "select",
      "id": "review_selection",
      "label": "Show reviews from",
      "default": "current_product",
      "options": [
        { "value": "current_product", "label": "Current product" },
        { "value": "custom_product", "label": "Custom product" },
        { "value": "current_collection", "label": "Current collection" },
        { "value": "store_reviews", "label": "Store reviews" }
      ]
    },
    {
      "type": "product",
      "id": "custom_product",
      "label": "Custom product"
    },
    {
      "type": "select",
      "id": "min_rating",
      "label": "Minimum rating",
      "default": "all",
      "options": [
        { "value": "all", "label": "All ratings" },
        { "value": "5", "label": "5 stars only" },
        { "value": "4", "label": "4 stars and above" },
        { "value": "3", "label": "3 stars and above" }
      ]
    },
    {
      "type": "range",
      "id": "max_reviews",
      "label": "Maximum reviews to load",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "Review text length",
      "min": 60,
      "max": 220,
      "step": 10,
      "default": 140
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty state text",
      "default": "No reviews available right now."
    },

    {
      "type": "header",
      "content": "Slider behavior"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto rotate",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto rotate speed (seconds)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_reviewer_name",
      "label": "Show reviewer name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_verified_badge",
      "label": "Show verified badge",
      "default": false
    },

    {
      "type": "header",
      "content": "Add to cart button"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show add to cart button",
      "default": true
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Button label",
      "default": "Add to cart"
    },
    {
      "type": "checkbox",
      "id": "redirect_to_cart",
      "label": "Redirect to cart after add",
      "default": true
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius",
      "min": 4,
      "max": 30,
      "step": 2,
      "default": 12
    },

    {
      "type": "header",
      "content": "Card layout"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width",
      "min": 280,
      "max": 900,
      "step": 10,
      "default": 650
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height",
      "min": 120,
      "max": 260,
      "step": 10,
      "default": 180
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "select",
      "id": "shadow_strength",
      "label": "Shadow strength",
      "default": "medium",
      "options": [
        { "value": "soft", "label": "Soft" },
        { "value": "medium", "label": "Medium" },
        { "value": "strong", "label": "Strong" }
      ]
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "reviewer_name_size",
      "label": "Reviewer name size",
      "min": 16,
      "max": 34,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "review_text_size",
      "label": "Review text size",
      "min": 14,
      "max": 28,
      "step": 1,
      "default": 18
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#178b7a"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e7ecea"
    }
  ]
}
{% endschema %}
