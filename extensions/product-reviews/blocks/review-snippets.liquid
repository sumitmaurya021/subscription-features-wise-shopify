{%- liquid
assign s=block.settings
assign src=s.review_selection | default:'current_product'
assign t='store'
assign id=''
assign h=''
assign ttl=shop.name
assign vid=''

case src
when 'custom_product'
  if s.custom_product!=blank
    assign t='product'
    assign id=s.custom_product.id
    assign h=s.custom_product.handle
    assign ttl=s.custom_product.title
    if s.custom_product.selected_or_first_available_variant
      assign vid=s.custom_product.selected_or_first_available_variant.id
    endif
  endif
when 'current_product'
  if product
    assign t='product'
    assign id=product.id
    assign h=product.handle
    assign ttl=product.title
    if product.selected_or_first_available_variant
      assign vid=product.selected_or_first_available_variant.id
    endif
  endif
when 'custom_collection'
  if s.custom_collection!=blank
    assign t='collection'
    assign id=s.custom_collection.id
    assign h=s.custom_collection.handle
    assign ttl=s.custom_collection.title
  endif
when 'current_collection'
  if collection
    assign t='collection'
    assign id=collection.id
    assign h=collection.handle
    assign ttl=collection.title
  endif
endcase

if src=='store_reviews'
  assign t='store'
  assign id=''
  assign h=''
  assign ttl=shop.name
  assign vid=''
elsif id==blank
  if template.name=='product' and product
    assign t='product'
    assign id=product.id
    assign h=product.handle
    assign ttl=product.title
    if product.selected_or_first_available_variant
      assign vid=product.selected_or_first_available_variant.id
    endif
  elsif template.name=='collection' and collection
    assign t='collection'
    assign id=collection.id
    assign h=collection.handle
    assign ttl=collection.title
  else
    assign t='store'
    assign id=''
    assign h=''
    assign ttl=shop.name
    assign vid=''
  endif
endif

assign min=''
if s.min_rating!=blank and s.min_rating!='all'
  assign min=s.min_rating
endif

assign atc=false
if s.show_add_to_cart and t=='product' and vid!=blank
  assign atc=true
endif
-%}
<div id="rsn-root-{{ block.id }}" class="rsn-root" style="padding-top:{{ s.section_padding_top }}px;padding-bottom:{{ s.section_padding_bottom }}px;--rsn-card-bg:{{ s.card_bg }};--rsn-text-color:{{ s.text_color }};--rsn-star-color:{{ s.star_color }};--rsn-arrow-bg:{{ s.arrow_bg }};--rsn-arrow-color:{{ s.arrow_color }};--rsn-border-color:{{ s.border_color }};--rsn-card-radius:{{ s.card_radius }}px;--rsn-card-padding:{{ s.card_padding }}px;--rsn-card-max-width:{{ s.card_max_width }}px;--rsn-card-min-height:{{ s.card_min_height }}px;--rsn-name-size:{{ s.reviewer_name_size }}px;--rsn-text-size:{{ s.review_text_size }}px;--rsn-button-bg:{{ s.button_bg }};--rsn-button-text:{{ s.button_text_color }};--rsn-button-radius:{{ s.button_radius }}px;" data-shop="{{ shop.permanent_domain }}" data-endpoint="/apps/reviews" data-review-type="{{ t }}" data-target-id="{{ id }}" data-target-handle="{{ h }}" data-target-title="{{ ttl | escape }}" data-min-rating="{{ min }}" data-max-reviews="{{ s.max_reviews }}" data-show-arrows="{{ s.show_arrows }}" data-autoplay="{{ s.autoplay }}" data-autoplay-speed="{{ s.autoplay_speed }}" data-pause-on-hover="{{ s.pause_on_hover }}" data-show-reviewer-name="{{ s.show_reviewer_name }}" data-show-verified-badge="{{ s.show_verified_badge }}" data-excerpt-length="{{ s.excerpt_length }}" data-shadow-strength="{{ s.shadow_strength }}" data-empty-text="{{ s.empty_text | escape }}" data-show-add-to-cart="{{ atc }}" data-add-to-cart-label="{{ s.add_to_cart_label | escape }}" data-add-to-cart-variant-id="{{ vid }}" data-redirect-to-cart="{{ s.redirect_to_cart }}" data-main-script="{{ 'review-snippets-main.js' | asset_url }}" {{ block.shopify_attributes }}></div>

{% schema %}
{"name":"Review Snippets","target":"section","templates":["product","collection","index"],"javascript":"review-snippets.js","stylesheet":"review-snippets.css","settings":[{"type":"header","content":"Review source"},{"type":"select","id":"review_selection","label":"Show reviews from","default":"current_product","options":[{"value":"current_product","label":"Current product"},{"value":"custom_product","label":"Custom product"},{"value":"current_collection","label":"Current collection"},{"value":"custom_collection","label":"Custom collection"},{"value":"store_reviews","label":"Store reviews"}]},{"type":"product","id":"custom_product","label":"Custom product"},{"type":"collection","id":"custom_collection","label":"Custom collection"},{"type":"select","id":"min_rating","label":"Minimum rating","default":"all","options":[{"value":"all","label":"All ratings"},{"value":"5","label":"5 stars only"},{"value":"4","label":"4 stars and above"},{"value":"3","label":"3 stars and above"}]},{"type":"range","id":"max_reviews","label":"Maximum reviews to load","min":3,"max":20,"step":1,"default":8},{"type":"range","id":"excerpt_length","label":"Review text length","min":60,"max":220,"step":10,"default":140},{"type":"text","id":"empty_text","label":"Empty state text","default":"No reviews available right now."},{"type":"header","content":"Slider behavior"},{"type":"checkbox","id":"show_arrows","label":"Show arrows","default":true},{"type":"checkbox","id":"autoplay","label":"Auto rotate","default":true},{"type":"range","id":"autoplay_speed","label":"Auto rotate speed (seconds)","min":3,"max":12,"step":1,"default":5},{"type":"checkbox","id":"pause_on_hover","label":"Pause on hover","default":true},{"type":"checkbox","id":"show_reviewer_name","label":"Show reviewer name","default":true},{"type":"checkbox","id":"show_verified_badge","label":"Show verified badge","default":false},{"type":"header","content":"Add to cart button"},{"type":"checkbox","id":"show_add_to_cart","label":"Show add to 