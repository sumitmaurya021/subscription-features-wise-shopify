<div
  id="prvc-root-{{ block.id }}"
  class="prvc-root"
  data-block-id="{{ block.id }}"
  data-app-script="{{ 'video-reviews-carousel-main.js' | asset_url }}"
  style="
    --prvc-max-width: {{ block.settings.maximum_width }}px;
    --prvc-section-pt: {{ block.settings.padding_top }}px;
    --prvc-section-pb: {{ block.settings.padding_bottom }}px;
  "
  {{ block.shopify_attributes }}
>
  <script type="application/json" data-prvc-config>
    {
      "shop": {{ shop.permanent_domain | json }},
      "endpoint": {{ '/apps/reviews' | json }},
      "productId": {{ product.id | json }},
      "selectedProductId": {% if block.settings.custom_product != blank %}{{ block.settings.custom_product.id | json }}{% else %}null{% endif %},
      "showSampleReviews": {{ block.settings.show_sample_reviews | json }},
      "reviewSelection": {{ block.settings.review_selection | json }},
      "starRating": {{ block.settings.star_rating | json }},
      "reviewType": {{ block.settings.review_type | json }},
      "maxReviews": {{ block.settings.maximum_review_number | json }},
      "showReviewerName": {{ block.settings.show_reviewer_name | json }},
      "autoplayMedia": {{ block.settings.autoplay_media | json }},
      "transitionSpeed": {{ block.settings.transition_speed | json }},
      "headerText": {{ block.settings.header_text | json }},
      "showAverageRating": {{ block.settings.show_average_rating | json }}
    }
  </script>

  <div class="prvc-mount" data-prvc-mount></div>
</div>

{% schema %}
{
  "name": "Videos Carousel",
  "target": "section",
  "templates": ["product", "index", "collection", "page"],
  "javascript": "video-reviews-carousel.js",
  "stylesheet": "video-reviews-carousel.css",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_sample_reviews",
      "label": "Show sample reviews (Preview only)",
      "default": false
    },
    {
      "type": "select",
      "id": "review_selection",
      "label": "Reviews selection",
      "default": "current_product",
      "options": [
        { "value": "current_product", "label": "Current product" },
        { "value": "all_reviews", "label": "All reviews" },
        { "value": "custom_product", "label": "Custom product" }
      ]
    },
    {
      "type": "product",
      "id": "custom_product",
      "label": "Select product"
    },
    {
      "type": "select",
      "id": "star_rating",
      "label": "Star rating",
      "default": "all",
      "options": [
        { "value": "all", "label": "All" },
        { "value": "5", "label": "5 stars" },
        { "value": "4", "label": "4 stars" },
        { "value": "3", "label": "3 stars" },
        { "value": "2", "label": "2 stars" },
        { "value": "1", "label": "1 star" }
      ]
    },
    {
      "type": "select",
      "id": "review_type",
      "label": "Review type",
      "default": "any",
      "options": [
        { "value": "any", "label": "Any review" },
        { "value": "uploaded", "label": "Uploaded video only" },
        { "value": "youtube", "label": "YouTube only" }
      ]
    },
    {
      "type": "range",
      "id": "maximum_review_number",
      "label": "Maximum review number",
      "min": 3,
      "max": 30,
      "step": 1,
      "default": 9
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Heading text",
      "default": "Customers are saying"
    },
    {
      "type": "checkbox",
      "id": "show_reviewer_name",
      "label": "Show reviewer name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_average_rating",
      "label": "Show average rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay_media",
      "label": "Autoplay center video",
      "default": true
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Auto slide speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "range",
      "id": "maximum_width",
      "label": "Maximum width",
      "min": 700,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ]
}
{% endschema %}
