{% capture current_collection_ids %}{% if collection %}{% for collection_product in collection.products limit: 50 %}{{ collection_product.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}{% endcapture %}{% capture selected_product_ids %}{% if block.settings.selected_products != blank %}{% for selected_product in block.settings.selected_products %}{{ selected_product.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}{% endcapture %}

<div class="prcc-root is-loading" aria-busy="true" data-endpoint="/apps/reviews" data-shop="{{ shop.permanent_domain }}" data-app-script="{{ 'review-cards-carousel-main.js' | asset_url }}" data-show-sample-reviews="{{ block.settings.show_sample_reviews }}" data-reviews-selection="{{ block.settings.reviews_selection }}" data-custom-product-ids="{{ selected_product_ids | strip | escape }}" data-current-product-id="{{ product.id }}" data-current-collection-product-ids="{{ current_collection_ids | strip | escape }}" data-current-product-image="{% if product and product.featured_image %}{{ product.featured_image | image_url: width: 1000 }}{% endif %}" data-star-rating="{{ block.settings.star_rating }}" data-show-review-media="{{ block.settings.show_review_media }}" data-display-order="{{ block.settings.display_order }}" data-no-image-fallback="{{ block.settings.no_image_fallback }}" data-max-review-number="{{ block.settings.maximum_review_number }}" data-review-length="{{ block.settings.review_length }}" data-text-size="{{ block.settings.text_size }}" data-image-ratio="{{ block.settings.image_ratio }}" data-reviews-shown-desktop="{{ block.settings.reviews_shown_desktop }}" data-show-reviewer-name="{{ block.settings.show_reviewer_name }}" data-show-product-name="{{ block.settings.show_product_name }}" data-hide-arrows-mobile="{{ block.settings.hide_arrows_on_mobile }}" data-arrows-position="{{ block.settings.arrows_position }}" data-transition-speed="{{ block.settings.transition_speed }}" data-header-text="{{ block.settings.header_text | escape }}" data-average-rating-text="{{ block.settings.average_rating_text }}" data-show-verified-badge="{{ block.settings.show_verified_badge }}" style="--prcc-max-width:{{ block.settings.maximum_width }}px;--prcc-header-color:{{ block.settings.header_text_color }};--prcc-text-color:{{ block.settings.text_color }};--prcc-card-bg:{{ block.settings.card_color }};--prcc-stars-color:{{ block.settings.stars_color }};--prcc-arrows-color:{{ block.settings.arrows_color }};--prcc-verified-icon-size:{{ block.settings.verified_icon_size }}px;--prcc-verified-icon-color:{{ block.settings.verified_icon_color }};--prcc-verified-icon-bg:{{ block.settings.verified_icon_bg }};padding-top:{{ block.settings.padding_top }}px;padding-bottom:{{ block.settings.padding_bottom }}px;">
  <div class="prcc-shell prcc-corner--{{ block.settings.corner_styling }} prcc-text-size--{{ block.settings.text_size }} prcc-review-length--{{ block.settings.review_length }} prcc-image-ratio--{{ block.settings.image_ratio }} prcc-arrows--{{ block.settings.arrows_position }}{% if block.settings.hide_arrows_on_mobile %} prcc-hide-mobile-arrows{% endif %}">
    <div class="prcc-header"></div>
    <div class="prcc-slider-wrap"></div>
    <div class="prcc-empty" role="status" aria-live="polite" aria-label="Loading reviews"><div class="prcc-loader-wrap"><span class="prcc-spinner"></span></div></div>
  </div>
</div>

{% schema %}
{"name":"Cards Carousel","target":"section","templates":["product","collection","index","page"],"javascript":"review-cards-carousel.js","stylesheet":"review-cards-carousel.css","settings":[{"type":"checkbox","id":"show_sample_reviews","label":"Show sample reviews (Preview only)","default":false},{"type":"select","id":"reviews_selection","label":"Reviews selection","default":"all","options":[{"value":"all","label":"All"},{"value":"product_reviews","label":"Product reviews"},{"value":"store_reviews","label":"Store reviews"},{"value":"current_product","label":"Current product"},{"value":"current_collection","label":"Current collection"},{"value":"featured","label":"Featured"},{"value":"custom_products","label":"Custom products"}]},{"type":"product_list","id":"selected_products","label":"Select products (when \"Reviews selection\": Custom products)","limit":50},{"type":"select","id":"star_rating","label":"Star rating","default":"all","options":[{"value":"all","label":"All"},{"value":"5_only","label":"5-star only"},{"value":"4_to_5","label":"4 to 5-star only"},{"value":"3_to_5","label":"3 to 5-star only"}]},{"type":"checkbox","id":"show_review_media","label":"Show review media","default":true},{"type":"select","id":"display_order","label":"Display order","default":"media_first","options":[{"value":"media_first","label":"Media first"},{"value":"most_recent","label":"Most recent"}]},{"type":"select","id":"no_image_fallback","label":"No image fallback","default":"review_text_only","options":[{"value":"review_text_only","label":"Review text only"},{"value":"product_image","label":"Product image"}]},{"type":"range","id":"maximum_review_number","label":"Maximum review number","min":4,"max":40,"step":1,"default":20},{"type":"select","id":"review_length","label":"Review length","default":"medium","options":[{"value":"small","label":"Small"},{"value":"medium","label":"Medium"},{"value":"large","label":"Large"}]},{"type":"select","id":"text_size","label":"Text size","default":"medium","options":[{"value":"small","label":"Small"},{"value":"medium","label":"Medium"},{"value":"large","label":"Large"}]},{"type":"select","id":"image_ratio","label":"Image ratio","default":"ratio_1_1","options":[{"value":"ratio_4_3","label":"4:3"},{"value":"ratio_1_1","label":"1:1"},{"value":"ratio_3_4","label":"3:4"}]},{"type":"range","id":"reviews_shown_desktop","label":"Reviews shown on desktop","min":1,"max":6,"step":1,"default":4},{"type":"checkbox","id":"show_reviewer_name","label":"Show reviewer name","default":true},{"type":"checkbox","id":"show_product_name","label":"Show product name","default":true},{"type":"checkbox","id":"hide_arrows_on_mobile","label":"Hide arrows on mobile","default":false},{"type":"select","id":"arrows_position","label":"Arrows position","default":"sides","options":[{"value":"sides","label":"Sides"},{"value":"bottom","label":"Bottom"}]},{"type":"range","id":"maximum_width","label":"Maximum width","min":700,"max":1440,"step":10,"default":1100},{"type":"select","id":"corner_styling","label":"Corner styling","default":"soft","options":[{"value":"square","label":"Square"},{"value":"soft","label":"Soft"},{"value":"round","label":"Round"},{"value":"extra_round","label":"Extra round"}]},{"type":"color","id":"header_text_color","label":"Header text color","default":"#000000"},{"type":"color","id":"text_color","label":"Text color","default":"#111111"},{"type":"color","id":"card_color","label":"Card color","default":"#F9F9F9"},{"type":"color","id":"stars_color","label":"Stars color","default":"#0F766E"},{"type":"color","id":"arrows_color","label":"Arrows color","default":"#000000"},{"type":"range","id":"transition_speed","label":"Transition speed (seconds)","min":1,"max":10,"step":1,"default":5},{"type":"text","id":"header_text","label":"Header text","default":"Customers are saying"},{"type":"checkbox","id":"average_rating_text","label":"Average rating text","default":true},{"type":"checkbox","id":"show_verified_badge","label":"Show verified badge","default":true},{"type":"range","id":"verified_icon_size","label":"Verified icon size","min":12,"max":28,"step":1,"default":16},{"type":"color","id":"verified_icon_color","label":"Verified icon color","default":"#15803D"},{"type":"color","id":"verified_icon_bg","label":"Verified icon background","default":"#D1FAE5"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"default":32},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"default":32}]}
{% endschema %}
