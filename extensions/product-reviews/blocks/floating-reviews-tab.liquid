<div
  id="frt-root-{{ block.id }}"
  class="frt-root"
  data-block-id="{{ block.id }}"
  data-app-script="{{ 'floating-reviews-tab-main.js' | asset_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-endpoint="/apps/reviews"
  data-review-type="store"
  data-position="{{ block.settings.tab_position }}"
  data-tab-label="{{ block.settings.tab_label | escape }}"
  data-panel-title="{{ block.settings.panel_title | escape }}"
  data-max-reviews="{{ block.settings.max_reviews }}"
  data-hide-trigger-when-open="{{ block.settings.hide_badge_on_open }}"
  style="
    --frt-badge-top: {{ block.settings.badge_top }}%;
    --frt-mobile-bottom: {{ block.settings.mobile_bottom }}px;
    --frt-badge-width: {{ block.settings.badge_width }}px;
    --frt-badge-height: {{ block.settings.badge_height }}px;
    --frt-badge-radius: {{ block.settings.badge_radius }}px;
    --frt-badge-padding-y: {{ block.settings.badge_padding_y }}px;
    --frt-badge-padding-x: {{ block.settings.badge_padding_x }}px;
    --frt-badge-font-family: {{ block.settings.badge_font_family }};
    --frt-badge-star-size: {{ block.settings.badge_star_size }}px;
    --frt-badge-rating-size: {{ block.settings.badge_rating_size }}px;
    --frt-badge-count-size: {{ block.settings.badge_count_size }}px;
    --frt-panel-width: {{ block.settings.panel_width }}px;
    --frt-badge-bg-start: {{ block.settings.badge_bg_start }};
    --frt-badge-bg-end: {{ block.settings.badge_bg_end }};
    --frt-badge-text: {{ block.settings.badge_text_color }};
    --frt-badge-count: {{ block.settings.badge_count_color }};
    --frt-star-active: {{ block.settings.badge_star_active_color }};
    --frt-star-inactive: {{ block.settings.badge_star_inactive_color }};
  "
>
  <button
    type="button"
    class="frt-trigger frt-trigger--{{ block.settings.tab_position }}"
    aria-expanded="false"
    aria-controls="frt-panel-{{ block.id }}"
    aria-label="{{ block.settings.tab_label | escape }}"
  >
    <span class="frt-trigger-inner">
      <span class="frt-trigger-gloss"></span>
      <span class="frt-trigger-edge"></span>

      <span class="frt-trigger-top" aria-hidden="true">
        <span class="frt-stars-vertical">
          {% for i in (1..5) %}
            <span class="frt-star" data-star-index="{{ i }}">★</span>
          {% endfor %}
        </span>
      </span>

      <span class="frt-trigger-middle">
        <span class="frt-rating-value">--</span>
      </span>
    </span>
  </button>

  <div id="frt-panel-{{ block.id }}" class="frt-panel frt-panel--{{ block.settings.tab_position }}" hidden>
    <div class="frt-overlay" data-frt-close="true"></div>

    <div class="frt-dialog" role="dialog" aria-modal="true" aria-label="{{ block.settings.panel_title | escape }}">
      <div class="frt-header">
        <div class="frt-header-content">
          <div class="frt-eyebrow">{{ block.settings.tab_label }}</div>
          <h3 class="frt-title">{{ block.settings.panel_title }}</h3>

          <div class="frt-summary">
            <span class="frt-summary-stars" aria-hidden="true">
              {% for i in (1..5) %}
                <span class="frt-summary-star" data-summary-star-index="{{ i }}">★</span>
              {% endfor %}
            </span>
            <span class="frt-summary-rating">--</span>
            <span class="frt-summary-count">Loading...</span>
          </div>
        </div>

        <button type="button" class="frt-close" aria-label="Close reviews panel">×</button>
      </div>

      <div class="frt-body">
        <div class="frt-loading">
          <div class="frt-loading-line frt-loading-line--lg"></div>
          <div class="frt-loading-line"></div>
          <div class="frt-loading-line"></div>
          <div class="frt-loading-line"></div>
        </div>

        <div class="frt-list" hidden></div>

        <div class="frt-empty" hidden>
          <div class="frt-empty-icon">⭐</div>
          <h4>No store reviews yet</h4>
          <p>Once approved store reviews are available, they will appear here.</p>
        </div>

        <div class="frt-error" hidden>Failed to load store reviews.</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{"name":"Floating Reviews Tab","target":"body","stylesheet":"floating-reviews-tab.css","javascript":"floating-reviews-tab.js","settings":[{"type":"paragraph","content":"Enable this app embed from the theme customizer to show a floating store-reviews tab across the site."},{"type":"header","content":"Content"},{"type":"text","id":"tab_label","label":"Tab label","default":"Store Reviews"},{"type":"text","id":"panel_title","label":"Panel title","default":"What customers say about our store"},{"type":"range","id":"max_reviews","label":"Maximum reviews to show","min":3,"max":20,"step":1,"default":12},{"type":"checkbox","id":"hide_badge_on_open","label":"Hide badge when panel opens","default":true},{"type":"header","content":"Position"},{"type":"select","id":"tab_position","label":"Tab position","default":"right","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}]},{"type":"range","id":"badge_top","label":"Desktop vertical position (%)","min":10,"max":90,"step":1,"default":50},{"type":"range","id":"mobile_bottom","label":"Mobile bottom spacing","min":0,"max":80,"step":1,"default":18},{"type":"header","content":"Badge size"},{"type":"range","id":"badge_width","label":"Badge width","min":54,"max":120,"step":1,"default":72},{"type":"range","id":"badge_height","label":"Badge height","min":160,"max":300,"step":2,"default":214},{"type":"range","id":"badge_radius","label":"Badge corner radius","min":8,"max":30,"step":1,"default":18},{"type":"range","id":"badge_padding_y","label":"Badge vertical padding","min":6,"max":24,"step":1,"default":14},{"type":"range","id":"badge_padding_x","label":"Badge horizontal padding","min":6,"max":20,"step":1,"default":10},{"type":"range","id":"panel_width","label":"Panel width","min":320,"max":520,"step":4,"default":420},{"type":"header","content":"Typography"},{"type":"text","id":"badge_font_family","label":"Badge font family","default":"Open Sans, sans-serif"},{"type":"range","id":"badge_star_size","label":"Star size","min":12,"max":28,"step":1,"default":18},{"type":"range","id":"badge_rating_size","label":"Rating font size","min":16,"max":36,"step":1,"default":28},{"type":"range","id":"badge_count_size","label":"Review count font size","min":9,"max":16,"step":1,"default":11},{"type":"header","content":"Colors"},{"type":"color","id":"badge_bg_start","label":"Badge background start","default":"#0b3b66"},{"type":"color","id":"badge_bg_end","label":"Badge background end","default":"#123f6d"},{"type":"color","id":"badge_text_color","label":"Badge text color","default":"#ffffff"},{"type":"color","id":"badge_count_color","label":"Badge count text color","default":"#dbeafe"},{"type":"color","id":"badge_star_active_color","label":"Filled star color","default":"#ffffff"},{"type":"color","id":"badge_star_inactive_color","label":"Empty star color","default":"#8eb4d6"}]}
{% endschema %}