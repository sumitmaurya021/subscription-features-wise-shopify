{% liquid
  assign review_type = 'store'
  assign target_id = ''
  assign target_handle = ''
  assign target_title = shop.name
  assign context_label = 'Store'
  assign context_subheading = 'See what customers are saying about our store'
  assign form_subtext = 'Tell other shoppers about your experience with our store'
  assign review_subject_text = 'store'
  assign context_image = ''

  if template.name == 'product' and product
    assign review_type = 'product'
    assign target_id = product.id
    assign target_handle = product.handle
    assign target_title = product.title
    assign context_label = 'Product'
    assign context_subheading = 'See what other buyers are saying about this product'
    assign form_subtext = 'Tell other shoppers about your experience with this product'
    assign review_subject_text = 'product'
    if product.featured_image
      assign context_image = product.featured_image | image_url: width: 800
    endif
  elsif template.name == 'collection' and collection
    assign review_type = 'collection'
    assign target_id = collection.id
    assign target_handle = collection.handle
    assign target_title = collection.title
    assign context_label = 'Collection'
    assign context_subheading = 'See what shoppers are saying about this collection'
    assign form_subtext = 'Tell other shoppers about your experience with this collection'
    assign review_subject_text = 'collection'
    if collection.image
      assign context_image = collection.image | image_url: width: 800
    endif
  endif
%}

<div
  id="product-reviews-root"
  data-review-type="{{ review_type }}"
  data-target-id="{{ target_id }}"
  data-target-handle="{{ target_handle }}"
  data-target-title="{{ target_title | escape }}"
  data-context-label="{{ context_label | escape }}"
  data-context-subheading="{{ context_subheading | escape }}"
  data-form-subtext="{{ form_subtext | escape }}"
  data-review-subject="{{ review_subject_text | escape }}"
  data-context-image="{{ context_image }}"
  data-product-id="{% if review_type == 'product' %}{{ product.id }}{% endif %}"
  data-product-title="{% if review_type == 'product' %}{{ product.title | escape }}{% endif %}"
  data-shop="{{ shop.permanent_domain }}"
  data-endpoint="/apps/reviews"
  data-cloudinary-cloud-name="{{ block.settings.cloudinary_cloud_name }}"
  data-cloudinary-upload-preset="{{ block.settings.cloudinary_upload_preset }}"
  data-main-script="{{ 'product-reviews-main.js' | asset_url }}"
>
  <div class="pr-widget">
    <div class="pr-shell">
      <div class="pr-skeleton-card" style="min-height: 220px;"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Write Reviews",
  "target": "section",
  "templates": ["product", "collection", "index"],
  "javascript": "product-reviews.js",
  "stylesheet": "product-reviews.css",
  "settings": [
    {
      "type": "text",
      "id": "cloudinary_cloud_name",
      "label": "Cloudinary Cloud Name"
    },
    {
      "type": "text",
      "id": "cloudinary_upload_preset",
      "label": "Cloudinary Upload Preset"
    }
  ]
}
{% endschema %}
