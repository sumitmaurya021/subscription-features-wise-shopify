{% capture selected_product_ids %}{% if block.settings.selected_products != blank %}{% for p in block.settings.selected_products %}{{ p.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}{% endcapture %}{% capture v_icon %}<svg viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M10 1.7 12.2 3l2.5-.2 1.2 2.2 2 1.5-.7 2.4.7 2.4-2 1.5-1.2 2.2-2.5-.2-2.2 1.2-2.2-1.2-2.5.2-1.2-2.2-2-1.5.7-2.4-.7-2.4 2-1.5 1.2-2.2 2.5.2L10 1.7Zm-1 10.5 5-5-1.1-1.1L9 9.9 7.2 8.1 6.1 9.2 9 12.2Z" fill="currentColor"/></svg>{% endcapture %}<div id="tc-root-{{ block.id }}" class="tc-root" data-block-id="{{ block.id }}" data-endpoint="/apps/reviews" data-shop="{{ shop.permanent_domain }}" data-app-script="{{ 'testimonials-carousel-main.js' | asset_url }}" data-review-selection="{{ block.settings.review_selection }}" data-star-rating-filter="{{ block.settings.star_rating_filter }}" data-max-reviews="{{ block.settings.max_reviews }}" data-show-sample-reviews="{{ block.settings.show_sample_reviews }}" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}" data-collection-id="{{ collection.id }}" data-collection-handle="{{ collection.handle }}" data-selected-product-ids="{{ selected_product_ids | strip }}" data-verified-reviewer-style="icon_text" data-verified-icon-shape="circle" data-show-verified-label="{{ block.settings.show_verified_label }}" data-transition-speed="{{ block.settings.transition_speed }}" data-arrows-position="{{ block.settings.arrows_position }}" style="padding-top:{{ block.settings.padding_top | default: 0 }}px;padding-bottom:{{ block.settings.padding_bottom | default: 0 }}px;--tc-max-width:{{ block.settings.maximum_width }}px;--tc-card-color:{{ block.settings.card_color }};--tc-accent-color:{{ block.settings.accent_color }};--tc-text-color:{{ block.settings.text_color }};--tc-arrows-color:{{ block.settings.arrows_color }};--tc-verified-icon-size:{{ block.settings.verified_icon_size }}px;--tc-verified-icon-color:{{ block.settings.verified_icon_color }};--tc-verified-icon-bg:{{ block.settings.verified_icon_bg_color }};--tc-verified-icon-border:{{ block.settings.verified_icon_border_color }};--tc-verified-label-size:{{ block.settings.verified_label_size }}px;--tc-verified-label-color:{{ block.settings.verified_label_color }};"><div class="tc-widget tc-quote-size--medium tc-quote-style--serif tc-product-size--small tc-corner--{{ block.settings.corner_styling }} tc-card-height--{{ block.settings.card_height }} tc-text-size--{{ block.settings.text_size }} tc-stars-size--{{ block.settings.stars_size }} tc-arrows-position--{{ block.settings.arrows_position }}{% if block.settings.show_border %} tc-has-border{% endif %}{% if block.settings.show_drop_shadow %} tc-has-shadow{% endif %}">{% if block.settings.header_text != blank or block.settings.show_average_rating_text %}<div class="tc-header">{% if block.settings.header_text != blank %}<h2 class="tc-heading">{{ block.settings.header_text }}</h2>{% endif %}<div class="tc-header-rating"{% unless block.settings.show_average_rating_text %} hidden{% endunless %}><span class="tc-header-stars" aria-hidden="true">★★★★★</span><span class="tc-header-rating-value">4.00</span><span class="tc-header-rating-count">(0)</span><span class="tc-header-rating-separator">•</span><span class="tc-header-rating-verified" aria-label="Verified reviews"><span class="tc-verified-icon tc-verified-icon--header">{{ v_icon }}</span><span class="tc-verified-label"{% unless block.settings.show_verified_label %} hidden{% endunless %}>Verified</span></span></div></div>{% endif %}<div class="tc-stage"><button type="button" class="tc-arrow tc-arrow--prev" aria-label="Previous testimonial"><span aria-hidden="true">‹</span></button><div class="tc-viewport"><div class="tc-track"><div class="tc-loading"><div class="tc-card tc-card--loading"><div class="tc-quote-mark">”</div><div class="tc-card-content"><div class="tc-loading-line tc-loading-line--lg"></div><div class="tc-loading-line"></div><div class="tc-loading-line"></div><div class="tc-loading-line tc-loading-line--md"></div><div class="tc-loading-stars">★★★★★</div><div class="tc-loading-line tc-loading-line--sm"></div><div class="tc-loading-line tc-loading-line--xs"></div></div></div></div></div></div><button type="button" class="tc-arrow tc-arrow--next" aria-label="Next testimonial"><span aria-hidden="true">›</span></button></div><div class="tc-bottom-arrows"{% if block.settings.arrows_position != 'bottom' %} hidden{% endif %}><button type="button" class="tc-arrow tc-arrow--prev-bottom" aria-label="Previous testimonial"><span aria-hidden="true">‹</span></button><button type="button" class="tc-arrow tc-arrow--next-bottom" aria-label="Next testimonial"><span aria-hidden="true">›</span></button></div><div class="tc-empty" hidden><div class="tc-empty-inner"><div class="tc-empty-icon">★</div><h3 class="tc-empty-title">No testimonials available</h3><p class="tc-empty-text">Approved reviews will appear here once they are available for the selected source.</p></div></div></div><template class="tc-card-template"><article class="tc-card"><div class="tc-quote-mark">”</div><div class="tc-card-content"><div class="tc-review-message"></div><div class="tc-review-stars" aria-hidden="true">★★★★★</div><div class="tc-review-author-row"><div class="tc-review-author"></div><div class="tc-review-verified" hidden aria-label="Verified reviewer"><span class="tc-verified-icon tc-verified-icon--card">{{ v_icon }}</span><span class="tc-verified-label"{% unless block.settings.show_verified_label %} hidden{% endunless %}>Verified reviewer</span></div></div><div class="tc-review-product"></div></div></article></template></div>{% schema %}{"name":"Testimonials Carousel","target":"section","stylesheet":"testimonials-carousel.css","javascript":"testimonials-carousel.js","settings":[{"type":"paragraph","content":"Display customer quotes to build trust and social proof."},{"type":"header","content":"Reviews selection"},{"type":"checkbox","id":"show_sample_reviews","label":"Show sample reviews (Preview only)","default":false},{"type":"select","id":"review_selection","label":"Reviews selection","default":"all","options":[{"value":"all","label":"All"},{"value":"product_reviews","label":"Product reviews"},{"value":"store_reviews","label":"Store reviews"},{"value":"current_product","label":"Current product"},{"value":"current_collection","label":"Current collection"},{"value":"featured","label":"Featured"},{"value":"custom_products","label":"Custom products"}]},{"type":"product_list","id":"selected_products","label":"Select products for custom selection"},{"type":"select","id":"star_rating_filter","label":"Star rating","default":"all","options":[{"value":"all","label":"All"},{"value":"5","label":"5-star only"},{"value":"4-5","label":"4 to 5-star only"},{"value":"3-5","label":"3 to 5-star only"}]},{"type":"range","id":"max_reviews","label":"Maximum review number","min":2,"max":40,"step":1,"default":20},{"type":"header","content":"Layout"},{"type":"range","id":"maximum_width","label":"Maximum width","min":400,"max":1600,"step":20,"unit":"px","default":1100},{"type":"range","id":"padding_top","label":"Top padding","min":0,"max":160,"step":4,"unit":"px","default":0},{"type":"range","id":"padding_bottom","label":"Bottom padding","min":0,"max":160,"step":4,"unit":"px","default":0},{"type":"select","id":"arrows_position","label":"Arrows position","default":"bottom","options":[{"value":"sides","label":"Sides"},{"value":"bottom","label":"Bottom"},{"value":"hidden","label":"Hidden"}]},{"type":"select","id":"corner_styling","label":"Corner styling","default":"soft","options":[{"value":"square","label":"Square"},{"value":"soft","label":"Soft"},{"value":"round","label":"Round"},{"value":"extra-round","label":"Extra round"}]},{"type":"select","id":"card_height","label":"Card height","default":"medium","options":[{"value":"compact","label":"Compact"},{"value":"medium","label":"Medium"},{"value":"tall","label":"Tall"},{"value":"extra-tall","label":"Extra tall"}]},{"type":"select","id":"text_size","label":"Text size","default":"small","options":[{"value":"extra-small","label":"Extra small"},{"value":"small","label":"Small"},{"value":"medium","label":"Medium"},{"value":"large","label":"Large"},{"value":"extra-large","label":"Extra large"},{"value":"huge","label":"Huge"}]},{"type":"select","id":"stars_size","label":"Stars size","default":"medium","options":[{"value":"small","label":"Small"},{"value":"medium","label":"Medium"},{"value":"large","label":"Large"},{"value":"hidden","label":"Hidden"}]},{"type":"header","content":"Style"},{"type":"color","id":"card_color","label":"Card color","default":"#F9F9F9"},{"type":"color","id":"accent_color","label":"Stars and quote marks color","default":"#108474"},{"type":"color","id":"text_color","label":"Text color","default":"#000000"},{"type":"color","id":"arrows_color","label":"Arrows color","default":"#000000"},{"type":"checkbox","id":"show_border","label":"Show border","default":false},{"type":"checkbox","id":"show_drop_shadow","label":"Show drop shadow","default":false},{"type":"range","id":"verified_icon_size","label":"Verified icon size","min":12,"max":40,"step":1,"unit":"px","default":16},{"type":"color","id":"verified_icon_color","label":"Verified icon color","default":"#108474"},{"type":"color","id":"verified_icon_bg_color","label":"Verified icon background","default":"#E7F7F4"},{"type":"color","id":"verified_icon_border_color","label":"Verified icon border color","default":"#BEE7DF"},{"type":"checkbox","id":"show_verified_label","label":"Show verified text with icon","default":false},{"type":"range","id":"verified_label_size","label":"Verified text size","min":10,"max":20,"step":1,"unit":"px","default":12},{"type":"color","id":"verified_label_color","label":"Verified text color","default":"#4B5563"},{"type":"header","content":"Header"},{"type":"text","id":"header_text","label":"Header text","default":"Customers are saying"},{"type":"checkbox","id":"show_average_rating_text","label":"Average rating text","default":false},{"type":"header","content":"Behavior"},{"type":"range","id":"transition_speed","label":"Transition speed","min":2,"max":60,"step":1,"unit":"s","default":60}]}{% endschema %}