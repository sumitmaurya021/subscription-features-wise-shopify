{% capture selected_product_ids %}{% if block.settings.selected_products != blank %}{% for selected_product in block.settings.selected_products %}{{ selected_product.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}{% endcapture %}

<div
  id="tc-root-{{ block.id }}"
  class="tc-root"
  data-block-id="{{ block.id }}"
  data-endpoint="/apps/reviews"
  data-shop="{{ shop.permanent_domain }}"
  data-app-script="{{ 'testimonials-carousel-main.js' | asset_url }}"
  data-review-selection="{{ block.settings.review_selection }}"
  data-star-rating-filter="{{ block.settings.star_rating_filter }}"
  data-max-reviews="{{ block.settings.max_reviews }}"
  data-show-sample-reviews="{{ block.settings.show_sample_reviews }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-collection-id="{{ collection.id }}"
  data-collection-handle="{{ collection.handle }}"
  data-selected-product-ids="{{ selected_product_ids | strip }}"
  data-verified-reviewer-style="{{ block.settings.verified_reviewer_style }}"
  data-transition-speed="{{ block.settings.transition_speed }}"
  data-arrows-position="{{ block.settings.arrows_position }}"
  style="--tc-max-width:{{ block.settings.maximum_width }}px;--tc-card-color:{{ block.settings.card_color }};--tc-accent-color:{{ block.settings.accent_color }};--tc-text-color:{{ block.settings.text_color }};--tc-arrows-color:{{ block.settings.arrows_color }};"
>
  <div
    class="
      tc-widget
      tc-corner--{{ block.settings.corner_styling }}
      tc-quote-size--{{ block.settings.quote_mark_size }}
      tc-quote-style--{{ block.settings.quote_marks_style }}
      tc-product-size--{{ block.settings.product_name_text_size }}
      tc-card-height--{{ block.settings.card_height }}
      tc-text-size--{{ block.settings.text_size }}
      tc-stars-size--{{ block.settings.stars_size }}
      tc-arrows-position--{{ block.settings.arrows_position }}
      {% if block.settings.show_border %} tc-has-border{% endif %}
      {% if block.settings.show_drop_shadow %} tc-has-shadow{% endif %}
    "
  >
    {% if block.settings.header_text != blank or block.settings.show_average_rating_text %}
      <div class="tc-header">
        {% if block.settings.header_text != blank %}
          <h2 class="tc-heading">{{ block.settings.header_text }}</h2>
        {% endif %}

        <div class="tc-header-rating" {% unless block.settings.show_average_rating_text %}hidden{% endunless %}>
          <span class="tc-header-stars" aria-hidden="true">★★★★★</span>
          <span class="tc-header-rating-value">4.00</span>
          <span class="tc-header-rating-count">(0)</span>
          <span class="tc-header-rating-separator">•</span>
          <span class="tc-header-rating-verified">
            <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
              <path d="M10 1.7l2.2 1.2 2.5-.2 1.2 2.2 2 1.5-.7 2.4.7 2.4-2 1.5-1.2 2.2-2.5-.2L10 18.3l-2.2-1.2-2.5.2-1.2-2.2-2-1.5.7-2.4-.7-2.4 2-1.5 1.2-2.2 2.5.2L10 1.7zm-1 10.5l5-5-1.1-1.1L9 9.9 7.2 8.1 6.1 9.2 9 12.2z" fill="currentColor"/>
            </svg>
            <span>Verified</span>
          </span>
        </div>
      </div>
    {% endif %}

    <div class="tc-stage">
      <button type="button" class="tc-arrow tc-arrow--prev" aria-label="Previous testimonial">
        <span aria-hidden="true">‹</span>
      </button>

      <div class="tc-viewport">
        <div class="tc-track">
          <div class="tc-loading">
            <div class="tc-card tc-card--loading">
              <div class="tc-quote-mark">”</div>
              <div class="tc-card-content">
                <div class="tc-loading-line tc-loading-line--lg"></div>
                <div class="tc-loading-line"></div>
                <div class="tc-loading-line"></div>
                <div class="tc-loading-line tc-loading-line--md"></div>
                <div class="tc-loading-stars">★★★★★</div>
                <div class="tc-loading-line tc-loading-line--sm"></div>
                <div class="tc-loading-line tc-loading-line--xs"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <button type="button" class="tc-arrow tc-arrow--next" aria-label="Next testimonial">
        <span aria-hidden="true">›</span>
      </button>
    </div>

    <div class="tc-bottom-arrows" {% if block.settings.arrows_position != 'bottom' %}hidden{% endif %}>
      <button type="button" class="tc-arrow tc-arrow--prev-bottom" aria-label="Previous testimonial">
        <span aria-hidden="true">‹</span>
      </button>
      <button type="button" class="tc-arrow tc-arrow--next-bottom" aria-label="Next testimonial">
        <span aria-hidden="true">›</span>
      </button>
    </div>

    <div class="tc-empty" hidden>
      <div class="tc-empty-inner">
        <div class="tc-empty-icon">★</div>
        <h3 class="tc-empty-title">No testimonials available</h3>
        <p class="tc-empty-text">Approved reviews will appear here once they are available for the selected source.</p>
      </div>
    </div>
  </div>

  <template class="tc-card-template">
    <article class="tc-card">
      <div class="tc-quote-mark">”</div>
      <div class="tc-card-content">
        <div class="tc-review-message"></div>
        <div class="tc-review-stars" aria-hidden="true">★★★★★</div>
        <div class="tc-review-author-row">
          <div class="tc-review-author"></div>
          <div class="tc-review-verified" hidden>
            <span class="tc-review-verified-badge">Verified</span>
            <span class="tc-review-verified-text">Verified reviewer</span>
          </div>
        </div>
        <div class="tc-review-product"></div>
      </div>
    </article>
  </template>
</div>

