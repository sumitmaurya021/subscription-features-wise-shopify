// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Review {
  id               String   @id @default(cuid())
  shop             String
  reviewType       String   @default("product")
  targetId         String?
  targetHandle     String?
  targetTitle      String?
  productId        String?
  productTitle     String?
  customerName     String
  customerEmail    String?
  rating           Int
  title            String?
  message          String
  reviewImages     String?
  reviewVideoUrl   String?
  reviewYoutubeUrl String?
  helpfulCount     Int      @default(0)
  status           String   @default("pending")
  isPinned         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([shop, reviewType])
  @@index([shop, reviewType, targetId])
  @@index([shop, reviewType, targetHandle])
  @@index([shop, productId])
}

model WishlistItem {
  id            String   @id @default(cuid())
  shop          String
  productId     String
  variantId     String   @default("")
  productTitle  String?
  productHandle String?
  productImage  String?
  productUrl    String?
  customerId    String?
  customerEmail String?
  sessionId     String?
  ownerKey      String
  ownerType     String   // "customer" | "guest"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, productId, variantId, ownerKey], name: "shop_product_variant_ownerKey")
}

model BackInStockRequest {
  id            String    @id @default(cuid())
  shop          String
  productId     String
  variantId     String    @default("")
  productTitle  String?
  productHandle String?
  productImage  String?
  productUrl    String?
  customerName  String?
  customerEmail String
  isActive      Boolean   @default(true)
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shop, productId, variantId, customerEmail], name: "shop_product_variant_email")
}

model PriceDropAlert {
  id                String   @id @default(cuid())
  shop              String
  productId         String
  productTitle      String?
  productHandle     String?
  customerEmail     String
  customerName      String?
  currentPrice      Float
  targetPrice       Float?
  lastNotifiedPrice Float?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, productId, customerEmail])
}

model LoyaltyCustomer {
  id                     String   @id @default(cuid())
  shop                   String
  customerId             String?
  customerEmail          String?
  sessionId              String?
  ownerKey               String
  firstName              String?
  lastName               String?
  pointsBalance          Int      @default(0)
  lifetimePointsEarned   Int      @default(0)
  lifetimePointsRedeemed Int      @default(0)
  tier                   String   @default("bronze")
  referralCode           String   @unique
  referredByCode         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  pointEvents            LoyaltyPointEvent[]
  redemptions            RewardRedemption[]
  referralsMade          ReferralInvite[] @relation("ReferrerRelation")

  @@unique([shop, ownerKey], name: "shop_ownerKey")
}

model LoyaltyPointEvent {
  id                String          @id @default(cuid())
  shop              String
  loyaltyCustomerId String
  eventType         String
  points            Int
  orderId           String?
  reviewId          String?
  note              String?
  status            String          @default("completed")
  createdAt         DateTime        @default(now())

  loyaltyCustomer   LoyaltyCustomer @relation(fields: [loyaltyCustomerId], references: [id], onDelete: Cascade)

  @@index([shop, loyaltyCustomerId])
}

model RewardRedemption {
  id                String          @id @default(cuid())
  shop              String
  loyaltyCustomerId String
  rewardKey         String
  rewardTitle       String
  rewardType        String
  pointsUsed        Int
  rewardCode        String?
  rewardValue       Float?
  status            String          @default("issued")
  createdAt         DateTime        @default(now())

  loyaltyCustomer   LoyaltyCustomer @relation(fields: [loyaltyCustomerId], references: [id], onDelete: Cascade)

  @@index([shop, loyaltyCustomerId])
}

model ReferralInvite {
  id                 String          @id @default(cuid())
  shop               String
  referrerCustomerId String
  referredEmail      String
  referralCode       String
  status             String          @default("pending")
  convertedOrderId   String?
  rewardPoints       Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  referrer           LoyaltyCustomer @relation("ReferrerRelation", fields: [referrerCustomerId], references: [id], onDelete: Cascade)

  @@unique([shop, referrerCustomerId, referredEmail], name: "shop_referrer_email")
  @@index([shop, referralCode])
}
